//@version=5
strategy("Aryan Price Action Framework", shorttitle = "Aryan PAF", overlay = true, max_bars_back = 500, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500, pyramiding = 0, initial_capital = 100000, commission_type = strategy.commission.percent, commission_value = 0.04)

//=============================================================================
// Inputs
//=============================================================================
structureGroup = "01. Structure"
liquidityGroup = "02. Liquidity / OB / FVG"
trendGroup = "03. Multi-Timeframe Trend"
riskGroup = "04. Strategy"
visualGroup = "05. Visuals"

showInternal = input.bool(true, "Show Internal Structure", group = structureGroup)
showSwing = input.bool(true, "Show Swing Structure", group = structureGroup)
showDashboard = input.bool(true, "Show Dashboard", group = structureGroup)
internalLen = input.int(5, "Internal Swing Length", minval = 2, group = structureGroup)
swingLen = input.int(20, "Swing Length", minval = 2, group = structureGroup)
mode = input.string("Dynamic", "Trend Engine Mode", options = ["Manual", "Dynamic"], group = structureGroup)

showOB = input.bool(true, "Show Institutional Order Blocks", group = liquidityGroup)
showFVG = input.bool(true, "Show Fair Value Gaps", group = liquidityGroup)
showSweeps = input.bool(true, "Show Liquidity Sweeps", group = liquidityGroup)
showZones = input.bool(true, "Show Premium / Discount", group = liquidityGroup)
requireFVG = input.bool(true, "Require FVG Confirmation", group = liquidityGroup)
obExtension = input.int(80, "OB Extension Bars", minval = 10, group = liquidityGroup)
fvgExtension = input.int(40, "FVG Extension Bars", minval = 10, group = liquidityGroup)

htf1 = input.timeframe("240", "Higher TF 1", group = trendGroup)
htf2 = input.timeframe("D", "Higher TF 2", group = trendGroup)
fastLen = input.int(20, "Fast EMA", minval = 2, group = trendGroup)
slowLen = input.int(50, "Slow EMA", minval = 2, group = trendGroup)

enableStrategy = input.bool(true, "Enable Strategy Mode", group = riskGroup)
riskATR = input.float(1.25, "Stop ATR Multiplier", step = 0.05, group = riskGroup)
trailATR = input.float(1.5, "Trailing ATR Multiplier", step = 0.05, group = riskGroup)
rewardRisk = input.float(2.5, "Reward / Risk", step = 0.1, group = riskGroup)
useSessionFilter = input.bool(false, "Use Session Filter", group = riskGroup)
tradeSession = input.session("0000-2359", "Trading Session", group = riskGroup)

bullColor = input.color(color.new(#089981, 0), "Bull Color", group = visualGroup)
bearColor = input.color(color.new(#f23645, 0), "Bear Color", group = visualGroup)
neutralColor = input.color(color.new(color.silver, 0), "Neutral Color", group = visualGroup)
zoneFill = input.color(color.new(color.blue, 88), "Zone Fill", group = visualGroup)

//=============================================================================
// Helpers
//=============================================================================
f_ema_trend(src, fastPeriod, slowPeriod) =>
    fastEma = ta.ema(src, fastPeriod)
    slowEma = ta.ema(src, slowPeriod)
    fastEma > slowEma ? 1 : fastEma < slowEma ? -1 : 0

f_body_high() => math.max(open, close)
f_body_low() => math.min(open, close)
f_is_bull() => close > open
f_is_bear() => close < open
f_trading_session() => not useSessionFilter or not na(time(timeframe.period, tradeSession))

//=============================================================================
// Core structure engine
//=============================================================================
atr = ta.atr(14)
internalHigh = ta.pivothigh(high, internalLen, internalLen)
internalLow = ta.pivotlow(low, internalLen, internalLen)
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow = ta.pivotlow(low, swingLen, swingLen)

var float lastInternalHigh = na
var float lastInternalLow = na
var float lastSwingHigh = na
var float lastSwingLow = na
var int internalTrend = 0
var int swingTrend = 0

if not na(internalHigh)
    lastInternalHigh := internalHigh
if not na(internalLow)
    lastInternalLow := internalLow
if not na(swingHigh)
    lastSwingHigh := swingHigh
if not na(swingLow)
    lastSwingLow := swingLow

internalBreakUp = not na(lastInternalHigh) and close > lastInternalHigh
internalBreakDown = not na(lastInternalLow) and close < lastInternalLow
swingBreakUp = not na(lastSwingHigh) and close > lastSwingHigh
swingBreakDown = not na(lastSwingLow) and close < lastSwingLow

internalBosUp = internalBreakUp and internalTrend >= 0
internalBosDown = internalBreakDown and internalTrend <= 0
internalChochUp = internalBreakUp and internalTrend < 0
internalChochDown = internalBreakDown and internalTrend > 0

swingBosUp = swingBreakUp and swingTrend >= 0
swingBosDown = swingBreakDown and swingTrend <= 0
swingChochUp = swingBreakUp and swingTrend < 0
swingChochDown = swingBreakDown and swingTrend > 0

if internalBreakUp
    internalTrend := 1
if internalBreakDown
    internalTrend := -1
if swingBreakUp
    swingTrend := 1
if swingBreakDown
    swingTrend := -1

//=============================================================================
// Liquidity and order-block logic
//=============================================================================
liquiditySweepLow = showSweeps and not na(lastInternalLow) and low < lastInternalLow - atr * 0.15 and close > lastInternalLow
liquiditySweepHigh = showSweeps and not na(lastInternalHigh) and high > lastInternalHigh + atr * 0.15 and close < lastInternalHigh

bullishFVG = low > high[2]
bearishFVG = high < low[2]

bullishBreak = internalBosUp or internalChochUp or swingBosUp or swingChochUp
bearishBreak = internalBosDown or internalChochDown or swingBosDown or swingChochDown

bullishOBHigh = ta.valuewhen(bullishBreak, math.max(open[1], close[1]), 0)
bullishOBLow = ta.valuewhen(bullishBreak, math.min(open[1], close[1]), 0)
bearishOBHigh = ta.valuewhen(bearishBreak, math.max(open[1], close[1]), 0)
bearishOBLow = ta.valuewhen(bearishBreak, math.min(open[1], close[1]), 0)

var box bullOBBox = na
var box bearOBBox = na
var box bullFVGBox = na
var box bearFVGBox = na

if showOB and bullishBreak and not na(bullishOBHigh) and not na(bullishOBLow)
    if not na(bullOBBox)
        box.delete(bullOBBox)
    bullOBBox := box.new(left = bar_index - 1, top = bullishOBHigh, right = bar_index + obExtension, bottom = bullishOBLow, xloc = xloc.bar_index, border_color = color.new(bullColor, 20), bgcolor = color.new(bullColor, 85))

if showOB and bearishBreak and not na(bearishOBHigh) and not na(bearishOBLow)
    if not na(bearOBBox)
        box.delete(bearOBBox)
    bearOBBox := box.new(left = bar_index - 1, top = bearishOBHigh, right = bar_index + obExtension, bottom = bearishOBLow, xloc = xloc.bar_index, border_color = color.new(bearColor, 20), bgcolor = color.new(bearColor, 85))

if showFVG and bullishFVG
    if not na(bullFVGBox)
        box.delete(bullFVGBox)
    bullFVGBox := box.new(left = bar_index - 2, top = low, right = bar_index + fvgExtension, bottom = high[2], xloc = xloc.bar_index, border_color = color.new(bullColor, 0), bgcolor = color.new(bullColor, 90))

if showFVG and bearishFVG
    if not na(bearFVGBox)
        box.delete(bearFVGBox)
    bearFVGBox := box.new(left = bar_index - 2, top = low[2], right = bar_index + fvgExtension, bottom = high, xloc = xloc.bar_index, border_color = color.new(bearColor, 0), bgcolor = color.new(bearColor, 90))

//=============================================================================
// Premium / discount and higher-timeframe trend
//=============================================================================
pdRangeHigh = nz(lastSwingHigh, high)
pdRangeLow = nz(lastSwingLow, low)
pdMid = math.avg(pdRangeHigh, pdRangeLow)
premium = close > pdMid
discount = close < pdMid

htfTrend1 = request.security(syminfo.tickerid, htf1, f_ema_trend(close, fastLen, slowLen), lookahead = barmerge.lookahead_off)
htfTrend2 = request.security(syminfo.tickerid, htf2, f_ema_trend(close, fastLen, slowLen), lookahead = barmerge.lookahead_off)
mtfTrend = htfTrend1 + htfTrend2
mtfBull = mtfTrend > 0
mtfBear = mtfTrend < 0

institutionalVolume = volume > ta.sma(volume, 20) * 1.25

//=============================================================================
// Strategy conditions
//=============================================================================
structureLong = internalBosUp or internalChochUp or swingBosUp or swingChochUp
structureShort = internalBosDown or internalChochDown or swingBosDown or swingChochDown
obLong = bullishBreak and not na(bullishOBHigh) and not na(bullishOBLow)
obShort = bearishBreak and not na(bearishOBHigh) and not na(bearishOBLow)
fvgLong = bullishFVG
fvgShort = bearishFVG

longSignal = enableStrategy and f_trading_session() and structureLong and obLong and liquiditySweepLow and mtfBull and (fvgLong or not requireFVG) and discount
shortSignal = enableStrategy and f_trading_session() and structureShort and obShort and liquiditySweepHigh and mtfBear and (fvgShort or not requireFVG) and premium

var float longStop = na
var float longTarget = na
var float shortStop = na
var float shortTarget = na

if longSignal and strategy.position_size <= 0
    entry = close
    longStop := entry - atr * riskATR
    longTarget := entry + (entry - longStop) * rewardRisk
    strategy.entry("Long", strategy.long)

if shortSignal and strategy.position_size >= 0
    entry = close
    shortStop := entry + atr * riskATR
    shortTarget := entry - (shortStop - entry) * rewardRisk
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    longStop := math.max(nz(longStop, close - atr * riskATR), close - atr * trailATR)
    strategy.exit("Long Exit", from_entry = "Long", stop = longStop, limit = longTarget)

if strategy.position_size < 0
    shortStop := math.min(nz(shortStop, close + atr * riskATR), close + atr * trailATR)
    strategy.exit("Short Exit", from_entry = "Short", stop = shortStop, limit = shortTarget)

if strategy.position_size == 0
    longStop := na
    longTarget := na
    shortStop := na
    shortTarget := na

//=============================================================================
// Visuals
//=============================================================================
plot(showZones ? pdMid : na, "Equilibrium", color = neutralColor, linewidth = 1, style = plot.style_line)
plotshape(showInternal and internalBosUp, title = "Internal BOS Up", style = shape.labelup, location = location.belowbar, color = bullColor, text = "BOS", textcolor = color.white, size = size.tiny)
plotshape(showInternal and internalChochUp, title = "Internal CHoCH Up", style = shape.labelup, location = location.belowbar, color = color.new(bullColor, 20), text = "CHoCH", textcolor = color.white, size = size.tiny)
plotshape(showInternal and internalBosDown, title = "Internal BOS Down", style = shape.labeldown, location = location.abovebar, color = bearColor, text = "BOS", textcolor = color.white, size = size.tiny)
plotshape(showInternal and internalChochDown, title = "Internal CHoCH Down", style = shape.labeldown, location = location.abovebar, color = color.new(bearColor, 20), text = "CHoCH", textcolor = color.white, size = size.tiny)
plotshape(showSweeps and liquiditySweepLow, title = "Liquidity Sweep Low", style = shape.triangleup, location = location.belowbar, color = bullColor, size = size.tiny, text = "SWP")
plotshape(showSweeps and liquiditySweepHigh, title = "Liquidity Sweep High", style = shape.triangledown, location = location.abovebar, color = bearColor, size = size.tiny, text = "SWP")
plotshape(longSignal, title = "Long Signal", style = shape.arrowup, location = location.belowbar, color = bullColor, size = size.small, text = "LONG")
plotshape(shortSignal, title = "Short Signal", style = shape.arrowdown, location = location.abovebar, color = bearColor, size = size.small, text = "SHORT")

barcolor(internalTrend > 0 ? color.new(bullColor, 55) : internalTrend < 0 ? color.new(bearColor, 55) : na)

//=============================================================================
// Dashboard panel
//=============================================================================
var table panel = table.new(position.top_right, 2, 10, frame_color = color.new(color.white, 80), border_color = color.new(color.white, 80), bgcolor = color.new(color.black, 8))
if showDashboard and barstate.islast
    table.cell(panel, 0, 0, "Aryan Price Action", text_color = color.white, bgcolor = color.new(color.black, 0), text_size = size.small)
    table.cell(panel, 1, 0, syminfo.ticker, text_color = color.silver, bgcolor = color.new(color.black, 0), text_size = size.small)
    table.cell(panel, 0, 1, "Internal Trend", text_color = color.silver)
    table.cell(panel, 1, 1, internalTrend > 0 ? "Bullish" : internalTrend < 0 ? "Bearish" : "Neutral", text_color = internalTrend > 0 ? bullColor : internalTrend < 0 ? bearColor : neutralColor)
    table.cell(panel, 0, 2, "Swing Trend", text_color = color.silver)
    table.cell(panel, 1, 2, swingTrend > 0 ? "Bullish" : swingTrend < 0 ? "Bearish" : "Neutral", text_color = swingTrend > 0 ? bullColor : swingTrend < 0 ? bearColor : neutralColor)
    table.cell(panel, 0, 3, "MTF Trend", text_color = color.silver)
    table.cell(panel, 1, 3, mtfBull ? "Bullish" : mtfBear ? "Bearish" : "Neutral", text_color = mtfBull ? bullColor : mtfBear ? bearColor : neutralColor)
    table.cell(panel, 0, 4, "Liquidity", text_color = color.silver)
    table.cell(panel, 1, 4, liquiditySweepLow ? "Sell-side sweep" : liquiditySweepHigh ? "Buy-side sweep" : "None", text_color = liquiditySweepLow ? bullColor : liquiditySweepHigh ? bearColor : neutralColor)
    table.cell(panel, 0, 5, "OB", text_color = color.silver)
    table.cell(panel, 1, 5, bullishBreak ? "Bullish" : bearishBreak ? "Bearish" : "Idle", text_color = bullishBreak ? bullColor : bearishBreak ? bearColor : neutralColor)
    table.cell(panel, 0, 6, "FVG", text_color = color.silver)
    table.cell(panel, 1, 6, bullishFVG ? "Bullish" : bearishFVG ? "Bearish" : "None", text_color = bullishFVG ? bullColor : bearishFVG ? bearColor : neutralColor)
    table.cell(panel, 0, 7, "Premium / Discount", text_color = color.silver)
    table.cell(panel, 1, 7, premium ? "Premium" : discount ? "Discount" : "Equilibrium", text_color = premium ? bearColor : discount ? bullColor : neutralColor)
    table.cell(panel, 0, 8, "Volume", text_color = color.silver)
    table.cell(panel, 1, 8, institutionalVolume ? "Institutional" : "Normal", text_color = institutionalVolume ? bullColor : neutralColor)
    table.cell(panel, 0, 9, "Signal", text_color = color.silver)
    table.cell(panel, 1, 9, longSignal ? "LONG" : shortSignal ? "SHORT" : "WAIT", text_color = longSignal ? bullColor : shortSignal ? bearColor : neutralColor)

//=============================================================================
// Alerts
//=============================================================================
alertcondition(internalBosUp, "Internal BOS Up", "Internal BOS Up")
alertcondition(internalBosDown, "Internal BOS Down", "Internal BOS Down")
alertcondition(internalChochUp, "Internal CHoCH Up", "Internal CHoCH Up")
alertcondition(internalChochDown, "Internal CHoCH Down", "Internal CHoCH Down")
alertcondition(swingBosUp, "Swing BOS Up", "Swing BOS Up")
alertcondition(swingBosDown, "Swing BOS Down", "Swing BOS Down")
alertcondition(swingChochUp, "Swing CHoCH Up", "Swing CHoCH Up")
alertcondition(swingChochDown, "Swing CHoCH Down", "Swing CHoCH Down")
alertcondition(liquiditySweepLow, "Liquidity Sweep Low", "Liquidity Sweep Low")
alertcondition(liquiditySweepHigh, "Liquidity Sweep High", "Liquidity Sweep High")
alertcondition(bullishFVG, "Bullish FVG", "Bullish FVG")
alertcondition(bearishFVG, "Bearish FVG", "Bearish FVG")
alertcondition(longSignal, "Long Entry", "Long Entry")
alertcondition(shortSignal, "Short Entry", "Short Entry")
